# Copy to .env (Docker Compose reads this automatically)

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# App encryption key (32 bytes recommended)
AJTRADE_DATA_KEY=replace-with-secure-32-byte-key

# Dev flags
AJTRADE_DEV_DISABLE_SECURE_COOKIE=1
AJTRADE_DEV_RETURN_TOKENS=1
