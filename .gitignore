.vscode/
.idea/
*.iml

# --- Environment files / secrets ---
# Never commit real secrets.
.env
.env.*
*.env

# Allow committing example/template env files.
!.env.example
!.env*.example
!.env.*.example

# --- Node / Next.js ---
node_modules/
.next/
out/
dist/
coverage/
.nyc_output/
.cache/
.turbo/

